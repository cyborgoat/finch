APP_NAME=Finch
APP_ENV=development
DATABASE_URL=sqlite:///./finch.db

DATA_DIR=./data
ORIGINAL_AUDIO_DIR=./data/audio/original
NORMALIZED_AUDIO_DIR=./data/audio/normalized
EXPORT_DIR=./data/exports

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini

ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
ASR_DEVICE=auto
ASR_DTYPE=auto
ASR_MOCK=true

HF_HOME=./data/hf_cache
TRANSFORMERS_CACHE=./data/hf_cache

LLM_MOCK=true

DIARIZATION_ENABLED=false
DIARIZATION_MOCK=true
DIARIZATION_PIPELINE_ID=pyannote/speaker-diarization-community-1
DIARIZATION_USE_ORIGINAL_AUDIO=false
DIARIZATION_USE_EXCLUSIVE=true
HF_TOKEN=

MAX_UPLOAD_MB=500
MAX_AUDIO_DURATION_SECONDS=7200
