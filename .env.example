APP_NAME=Finch
APP_ENV=development
DEBUG_MODE=false
DATABASE_URL=sqlite:///./finch.db

DATA_DIR=./data
ORIGINAL_AUDIO_DIR=./data/audio/original
NORMALIZED_AUDIO_DIR=./data/audio/normalized

ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B
ASR_DEVICE=auto
ASR_DTYPE=auto

HF_HOME=./data/hf_cache
TRANSFORMERS_CACHE=./data/hf_cache

# Diarization and voiceprint toggles are configured in Settings → Transcription.
# HF_TOKEN is required when diarization or voiceprint profiles are enabled.
DIARIZATION_ENABLED=false
DIARIZATION_PIPELINE_ID=pyannote/speaker-diarization-community-1
DIARIZATION_USE_ORIGINAL_AUDIO=false
DIARIZATION_USE_EXCLUSIVE=true
DIARIZATION_MIN_SEGMENT_SECONDS=0.3
DIARIZATION_MERGE_GAP_SECONDS=0.5
DIARIZATION_MAX_SEGMENTS=0
HF_TOKEN=

VOICEPRINT_PROFILES_ENABLED=false
SPEAKER_EMBEDDING_MODEL_ID=pyannote/embedding
SPEAKER_MATCH_THRESHOLD=0.75
SPEAKER_MIN_ENROLL_SECONDS=2.0

MAX_UPLOAD_MB=500
MAX_AUDIO_DURATION_SECONDS=7200

# Optional: SQLite-backed Huey job queue (defaults to {DATA_DIR}/huey.db)
# HUEY_DB_PATH=./data/huey.db
